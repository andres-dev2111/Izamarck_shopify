    { "type": "text",         "id": "item_label_4",  "label": "Badge género",    "default": "Mujer" },
    { "type": "text",         "id": "item_sub_4",    "label": "Subcategoría",    "default": "CONJUNTOS" },
    { "type": "text",         "id": "item_name_4",   "label": "Nombre producto", "default": "Conjunto Satinado" },
    { "type": "url",          "id": "item_link_4",   "label": "Enlace" }
  ],
  "presets": [{ "name": "IZAMARCK — Categorías" }]
}
{% endschema %}
