<div class="izamarck-categories">
  {%- comment -%} Top 2-column editorial panels {%- endcomment -%}
  <div class="izamarck-categories__top-grid">
    {%- for i in (1..2) -%}
      {%- liquid
        assign img_key  = 'top_image_' | append: i
        assign name_key = 'top_name_'  | append: i
        assign link_key = 'top_link_'  | append: i
        assign img      = section.settings[img_key]
        assign name     = section.settings[name_key]
        assign link     = section.settings[link_key] | default: '#'
      -%}
      <a href="{{ link }}" class="izamarck-cat-panel" style="text-decoration:none;">
        {%- if img != blank -%}
          <img
            src="{{ img | image_url: width: 900 }}"
            alt="{{ img.alt | escape | default: name }}"
            loading="lazy"
          >
        {%- else -%}
          {%- assign fallbacks = 'https://images.unsplash.com/photo-1767631338127-8cd80ee2f9df?w=900&q=80,https://images.unsplash.com/photo-1716004359569-052b4d8b3713?w=900&q=80' | split: ',' -%}
          <img
            src="{{ fallbacks[forloop.index0] }}"
            alt="{{ name }}"
            loading="lazy"
            style="width:100%;height:100%;object-fit:cover;object-position:top;"
          >
        {%- endif -%}
        <div class="izamarck-cat-panel__overlay"></div>
        <div class="izamarck-cat-panel__footer">
          <span class="izamarck-cat-panel__name">{{ name | default: 'Categoría' }}</span>
          <span class="izamarck-cat-panel__link">Ver Todo</span>
        </div>
      </a>
    {%- endfor -%}
  </div>

  {%- comment -%} Bottom 4-column grid {%- endcomment -%}
  <div class="izamarck-categories__bottom-grid">
    {%- for i in (1..4) -%}
      {%- liquid
        assign img_key  = 'grid_image_' | append: i
        assign name_key = 'grid_name_'  | append: i
        assign link_key = 'grid_link_'  | append: i
        assign img      = section.settings[img_key]
        assign name     = section.settings[name_key]
        assign link     = section.settings[link_key] | default: '#'
      -%}
      <a href="{{ link }}" class="izamarck-cat-panel izamarck-cat-panel--small" style="text-decoration:none;">
        {%- if img != blank -%}
          <img
            src="{{ img | image_url: width: 600 }}"
            alt="{{ img.alt | escape | default: name }}"
            loading="lazy"
          >
        {%- else -%}
          {%- assign grid_fallbacks = 'https://images.unsplash.com/photo-1704775989614-8435994e4e97?w=600&q=80,https://images.unsplash.com/photo-1750857740109-de17aae57783?w=600&q=80,https://images.unsplash.com/photo-1764347120228-947f575f9c82?w=600&q=80,https://images.unsplash.com/photo-1763971922558-0f3bd55abd60?w=600&q=80' | split: ',' -%}
          <img
            src="{{ grid_fallbacks[forloop.index0] }}"
            alt="{{ name }}"
            loading="lazy"
            style="width:100%;height:100%;object-fit:cover;object-position:top;"
          >
        {%- endif -%}
        <div class="izamarck-cat-panel__overlay"></div>
        <div class="izamarck-cat-panel__footer">
          <span class="izamarck-cat-panel__name">{{ name | default: 'Categoría' }}</span>
          <span class="izamarck-cat-panel__link">Ver Todo</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

