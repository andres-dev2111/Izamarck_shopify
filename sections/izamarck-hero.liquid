<div class="izamarck-hero">
  {%- assign hero_img = section.settings.hero_image -%}

  <div class="izamarck-hero__main">
    {%- if hero_img != blank -%}
      <img
        src="{{ hero_img | image_url: width: 1600 }}"
        alt="{{ hero_img.alt | escape | default: section.settings.hero_title }}"
        loading="eager"
        fetchpriority="high"
        style="width:100%;height:100%;object-fit:cover;object-position:top;"
      >
    {%- else -%}
      <img
        src="https://images.unsplash.com/photo-1769305171851-897e01aa095c?w=1600&q=80"
        alt="{{ section.settings.hero_title }}"
        loading="eager"
        style="width:100%;height:100%;object-fit:cover;object-position:top;"
      >
    {%- endif -%}

    <div class="izamarck-hero__main-overlay"></div>

    <div class="izamarck-hero__main-content">
      {%- if section.settings.eyebrow != blank -%}
        <span class="izamarck-hero__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}

      {%- if section.settings.hero_title != blank -%}
        <h1 class="izamarck-hero__title">{{ section.settings.hero_title }}</h1>
      {%- endif -%}

      {%- if section.settings.hero_subtitle != blank -%}
        <p class="izamarck-hero__subtitle">{{ section.settings.hero_subtitle }}</p>
      {%- endif -%}

      {%- comment -%} Gender nav buttons — matches new React design {%- endcomment -%}
      <div class="izamarck-hero__actions">
        {%- if section.settings.btn_mujer_label != blank -%}
          <a href="{{ section.settings.btn_mujer_link | default: '/collections/mujer' }}" class="izamarck-btn-primary">
            {{ section.settings.btn_mujer_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.btn_hombre_label != blank -%}
          <a href="{{ section.settings.btn_hombre_link | default: '/collections/hombre' }}" class="izamarck-hero__btn-outline">
            {{ section.settings.btn_hombre_label }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  /* Hero full-width — no mini banners (new v2 design) */
  .izamarck-hero__main {
    position: relative;
    height: clamp(420px, 60vw, 680px);
    overflow: hidden;
  }

  .izamarck-hero__main-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(0,0,0,0.80) 0%, rgba(0,0,0,0.40) 50%, transparent 100%);
  }

  .izamarck-hero__main-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 56px;
    max-width: 680px;
  }

  .izamarck-hero__eyebrow {
    color: #D4A843;
    font-size: 10px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .izamarck-hero__title {
    color: #ffffff;
    font-size: clamp(2.4rem, 5.5vw, 4rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
  }

  .izamarck-hero__subtitle {
    color: rgba(255,255,255,0.65);
    font-size: 14px;
    line-height: 1.65;
    max-width: 380px;
    margin-bottom: 32px;
  }

  .izamarck-hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px;
  }

  /* Outline button for "Hombre" — new in v2 */
  .izamarck-hero__btn-outline {
    display: inline-block;
    color: #ffffff !important;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none !important;
    border: 1px solid rgba(255,255,255,0.5);
    padding: 11px 28px;
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .izamarck-hero__btn-outline:hover {
    border-color: #D4A843 !important;
    color: #D4A843 !important;
  }

  @media screen and (max-width: 749px) {
    .izamarck-hero__main {
      height: clamp(380px, 70vw, 500px);
    }
    .izamarck-hero__main-content {
      padding: 0 24px;
      max-width: 100%;
    }
    .izamarck-hero__title {
      font-size: clamp(2rem, 8vw, 2.8rem);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "IZAMARCK — Hero Banner",
  "tag": "section",
  "class": "izamarck-hero-section",
  "settings": [
    { "type": "image_picker", "id": "hero_image",    "label": "Imagen principal" },
    { "type": "text",         "id": "eyebrow",       "label": "Texto pequeño",      "default": "Colección 2026" },
    { "type": "text",         "id": "hero_title",    "label": "Título",             "default": "Más\nVendidos" },
    { "type": "textarea",     "id": "hero_subtitle", "label": "Subtítulo",          "default": "Descubre los más vendidos que han conquistado a nuestros clientes por su perfecta combinación de funcionalidad y estilo." },
    { "type": "header",       "content": "Botones de género" },
    { "type": "text", "id": "btn_mujer_label",  "label": "Botón 1 — texto", "default": "Mujer" },
    { "type": "url",  "id": "btn_mujer_link",   "label": "Botón 1 — enlace" },
    { "type": "text", "id": "btn_hombre_label", "label": "Botón 2 — texto", "default": "Hombre" },
    { "type": "url",  "id": "btn_hombre_link",  "label": "Botón 2 — enlace" }
  ],
  "presets": [{ "name": "IZAMARCK — Hero Banner" }]
}
{% endschema %}
