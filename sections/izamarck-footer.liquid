    { "type": "url", "id": "privacy_url", "label": "Enlace Privacidad" },
    { "type": "url", "id": "cookies_url", "label": "Enlace Cookies" },
    { "type": "url", "id": "legal_url",   "label": "Enlace Legal" }
  ],
  "presets": [
    {
      "name": "IZAMARCK — Footer"
    }
  ]
