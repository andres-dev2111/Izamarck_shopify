<footer class="izamarck-footer">

  {%- comment -%} Ticker bar {%- endcomment -%}
  <div class="izamarck-footer__ticker-bar" aria-hidden="true">
    <div class="izamarck-footer__ticker-track">
      {%- for i in (1..8) -%}
        <span class="izamarck-footer__ticker-item">UNA COMUNIDAD DEDICADA AL DISFRUTE Y RESPETO A LA MODA · IZAMARCK ·</span>
      {%- endfor -%}
      {%- for i in (1..8) -%}
        <span class="izamarck-footer__ticker-item">UNA COMUNIDAD DEDICADA AL DISFRUTE Y RESPETO A LA MODA · IZAMARCK ·</span>
      {%- endfor -%}
    </div>
  </div>

  <div class="izamarck-footer__main">

    {%- comment -%} Logo + tagline {%- endcomment -%}
    <div class="izamarck-footer__logo-area">
      <a href="{{ routes.root_url }}" class="izamarck-footer__logo">
        {{ section.settings.logo_text | default: 'IZAMARCK' }}
      </a>
      <p class="izamarck-footer__tagline">
        {{ section.settings.tagline | default: 'Moda con identidad' }}
      </p>
    </div>

    {%- comment -%} Social icons {%- endcomment -%}
    <div class="izamarck-footer__socials">
      {%- if section.settings.instagram != blank -%}
        <a href="{{ section.settings.instagram }}" class="izamarck-footer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
      {%- endif -%}
      {%- if section.settings.facebook != blank -%}
        <a href="{{ section.settings.facebook }}" class="izamarck-footer__social-link" aria-label="Facebook" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
      {%- endif -%}
      {%- if section.settings.tiktok != blank -%}
        <a href="{{ section.settings.tiktok }}" class="izamarck-footer__social-link" aria-label="TikTok" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.79 1.54V6.78a4.85 4.85 0 01-1.02-.09z"/></svg>
        </a>
      {%- endif -%}
      {%- if section.settings.youtube != blank -%}
        <a href="{{ section.settings.youtube }}" class="izamarck-footer__social-link" aria-label="YouTube" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
      {%- endif -%}
      {%- if section.settings.spotify != blank -%}
        <a href="{{ section.settings.spotify }}" class="izamarck-footer__social-link" aria-label="Spotify" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.586 14.424a.623.623 0 01-.857.207c-2.348-1.435-5.304-1.76-8.785-.964a.623.623 0 11-.277-1.215c3.809-.87 7.076-.496 9.712 1.115a.623.623 0 01.207.857zm1.223-2.722a.78.78 0 01-1.072.257c-2.687-1.652-6.785-2.131-9.965-1.166a.78.78 0 01-.971-.519.781.781 0 01.519-.972c3.632-1.102 8.147-.568 11.233 1.328a.78.78 0 01.256 1.072zm.105-2.835C14.692 8.95 9.375 8.775 6.297 9.71a.937.937 0 11-.543-1.794c3.503-1.062 9.33-.857 13.004 1.329a.937.937 0 01-.844 1.622z"/></svg>
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} 3 link columns {%- endcomment -%}
    <div class="izamarck-footer__cols">
      {%- comment -%} Col 1 — Sobre la Marca {%- endcomment -%}
      <div>
        <h4 class="izamarck-footer__col-title">{{ section.settings.col1_title | default: 'Sobre la Marca' }}</h4>
        <ul class="izamarck-footer__col-links">
          {%- for i in (1..5) -%}
            {%- assign lbl_key  = 'col1_link' | append: i | append: '_label' -%}
            {%- assign href_key = 'col1_link' | append: i | append: '_url' -%}
            {%- assign lbl  = section.settings[lbl_key] -%}
            {%- assign href = section.settings[href_key] | default: '#' -%}
            {%- if lbl != blank -%}
              <li><a href="{{ href }}">{{ lbl }}</a></li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>

      {%- comment -%} Col 2 — Ayuda {%- endcomment -%}
      <div>
        <h4 class="izamarck-footer__col-title">{{ section.settings.col2_title | default: 'Ayuda' }}</h4>
        <ul class="izamarck-footer__col-links">
          {%- for i in (1..5) -%}
            {%- assign lbl_key  = 'col2_link' | append: i | append: '_label' -%}
            {%- assign href_key = 'col2_link' | append: i | append: '_url' -%}
            {%- assign lbl  = section.settings[lbl_key] -%}
            {%- assign href = section.settings[href_key] | default: '#' -%}
            {%- if lbl != blank -%}
              <li><a href="{{ href }}">{{ lbl }}</a></li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>

      {%- comment -%} Col 3 — Contacto (info, no links) {%- endcomment -%}
      <div>
        <h4 class="izamarck-footer__col-title">{{ section.settings.col3_title | default: 'Contacto' }}</h4>
        <ul class="izamarck-footer__col-links">
          {%- assign contact_items = section.settings.contact_info | newline_to_br | split: '<br />' -%}
          {%- for item in contact_items -%}
            {%- if item != blank -%}
              <li><span class="izamarck-footer__col-info-item">{{ item | strip }}</span></li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
    </div>

    {%- comment -%} Newsletter {%- endcomment -%}
    <div class="izamarck-footer__newsletter">
      <div>
        <p class="izamarck-footer__newsletter-label">Newsletter</p>
        <p class="izamarck-footer__newsletter-sub">
          {{ section.settings.newsletter_text | default: 'Suscríbete y recibe un 10% en tu primera compra.' }}
        </p>
      </div>
      {%- form 'customer', class: 'izamarck-footer__newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input
          class="izamarck-footer__newsletter-input"
          type="email"
          name="contact[email]"
          placeholder="{{ 'general.newsletter_form.email_placeholder' | t | default: 'Tu correo electrónico' }}"
          required
          autocomplete="email"
          aria-label="{{ 'general.newsletter_form.email_placeholder' | t | default: 'Tu correo electrónico' }}"
        >
        <button class="izamarck-footer__newsletter-btn" type="submit">OK</button>
      {%- endform -%}
    </div>

    {%- comment -%} Bottom bar {%- endcomment -%}
    <div class="izamarck-footer__bottom">
      <p class="izamarck-footer__copyright">
        {{ section.settings.copyright | default: '© 2026 IZAMARCK®. Todos los derechos reservados.' }}
      </p>
      <div class="izamarck-footer__legal-links">
        <a href="{{ section.settings.privacy_url | default: '#' }}">Privacidad</a>
        <a href="{{ section.settings.cookies_url | default: '#' }}">Cookies</a>
        <a href="{{ section.settings.legal_url   | default: '#' }}">Legal</a>
      </div>
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "IZAMARCK — Footer",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Marca"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Texto del logo",
      "default": "IZAMARCK"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Moda con identidad"
    },
    {
      "type": "header",
      "content": "Redes Sociales"
    },
    { "type": "url", "id": "instagram", "label": "Instagram" },
    { "type": "url", "id": "facebook",  "label": "Facebook" },
    { "type": "url", "id": "tiktok",    "label": "TikTok" },
    { "type": "url", "id": "youtube",   "label": "YouTube" },
    { "type": "url", "id": "spotify",   "label": "Spotify" },
    {
      "type": "header",
      "content": "Columna 1"
    },
    { "type": "text", "id": "col1_title", "label": "Título", "default": "Sobre la Marca" },
    { "type": "text", "id": "col1_link1_label", "label": "Enlace 1 — texto", "default": "Sobre Nosotros" },
    { "type": "url",  "id": "col1_link1_url",   "label": "Enlace 1 — URL" },
    { "type": "text", "id": "col1_link2_label", "label": "Enlace 2 — texto", "default": "Nuestra Historia" },
    { "type": "url",  "id": "col1_link2_url",   "label": "Enlace 2 — URL" },
    { "type": "text", "id": "col1_link3_label", "label": "Enlace 3 — texto", "default": "Cultura IZAMARCK" },
    { "type": "url",  "id": "col1_link3_url",   "label": "Enlace 3 — URL" },
    { "type": "text", "id": "col1_link4_label", "label": "Enlace 4 — texto", "default": "Trabaja con Nosotros" },
    { "type": "url",  "id": "col1_link4_url",   "label": "Enlace 4 — URL" },
    { "type": "text", "id": "col1_link5_label", "label": "Enlace 5 — texto", "default": "La Vida en IZAMARCK" },
    { "type": "url",  "id": "col1_link5_url",   "label": "Enlace 5 — URL" },
    {
      "type": "header",
      "content": "Columna 2"
    },
    { "type": "text", "id": "col2_title", "label": "Título", "default": "Ayuda" },
    { "type": "text", "id": "col2_link1_label", "label": "Enlace 1 — texto", "default": "Cambios, Devoluciones y Garantías" },
    { "type": "url",  "id": "col2_link1_url",   "label": "Enlace 1 — URL" },
    { "type": "text", "id": "col2_link2_label", "label": "Enlace 2 — texto", "default": "Términos y Condiciones" },
    { "type": "url",  "id": "col2_link2_url",   "label": "Enlace 2 — URL" },
    { "type": "text", "id": "col2_link3_label", "label": "Enlace 3 — texto", "default": "Política de Envíos" },
    { "type": "url",  "id": "col2_link3_url",   "label": "Enlace 3 — URL" },
    { "type": "text", "id": "col2_link4_label", "label": "Enlace 4 — texto", "default": "Preguntas Frecuentes" },
    { "type": "url",  "id": "col2_link4_url",   "label": "Enlace 4 — URL" },
    { "type": "text", "id": "col2_link5_label", "label": "Enlace 5 — texto", "default": "Escríbenos" },
    { "type": "url",  "id": "col2_link5_url",   "label": "Enlace 5 — URL" },
    {
      "type": "header",
      "content": "Columna 3 — Contacto"
    },
    { "type": "text", "id": "col3_title", "label": "Título", "default": "Contacto" },
    {
      "type": "textarea",
      "id": "contact_info",
      "label": "Información de contacto (una por línea)",
      "default": "NIT: 000.000.000-0\nWhatsApp: 300 000 00 00\nPBX: 01 8000 00 00 00\nMedellín, Colombia\ncontacto@izamarck.com"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "Texto del newsletter",
      "default": "Suscríbete y recibe un 10% en tu primera compra."
